{
  "info": {
    "name": "Learning MVP Backend Overhaul (Templates Update)",
    "description": "Complete collection for the updated backend, reflecting the new Template Engine for Sessions and Quizzes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"org@test.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"organization\",\n  \"orgName\": \"Acme Corp\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login Superadmin (Seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@system.com\",\n  \"password\": \"SuperAdmin123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Users & Admins",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "Complete Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": ["{{baseUrl}}"],
              "path": ["users", "profile"]
            }
          }
        },
        {
          "name": "Superadmin Creates Admin & Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@system.com\",\n  \"password\": \"AdminPassword1!\",\n  \"firstName\": \"System\",\n  \"lastName\": \"Admin\",\n  \"durationDays\": 30,\n  \"contentTemplateId\": \"<CONTENT_TEMPLATE_ID>\",\n  \"quizTemplateId\": \"<QUIZ_TEMPLATE_ID>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/admin",
              "host": ["{{baseUrl}}"],
              "path": ["users", "admin"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Templates (Superadmin)",
      "item": [
        {
          "name": "Create Content Template",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Content Template\",\n  \"description\": \"My test course\",\n  \"category\": \"general\",\n  \"contentItems\": [\n    {\n      \"day\": 1,\n      \"title\": \"Day 1 Intro\",\n      \"videoUrl\": \"https://example.com/vid1.mp4\",\n      \"duration\": 600\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/templates/content",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "content"]
            }
          }
        },
        {
          "name": "Create Quiz Template",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Quiz Template\",\n  \"description\": \"My test quiz\",\n  \"category\": \"general\",\n  \"quizDays\": [\n    {\n      \"day\": 1,\n      \"title\": \"Day 1 Quiz\",\n      \"questions\": [\n        {\n          \"question\": \"What is 2+2?\",\n          \"options\": [\"3\", \"4\", \"5\", \"6\"],\n          \"correctAnswer\": 1,\n          \"score\": 10\n        }\n      ],\n      \"timeLimit\": 300\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/templates/quiz",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "quiz"]
            }
          }
        },
        {
          "name": "Get All Templates",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/templates",
              "host": ["{{baseUrl}}"],
              "path": ["templates"]
            }
          }
        },
        {
          "name": "Get Template By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/templates/<TEMPLATE_ID>?type=content",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "<TEMPLATE_ID>"],
              "query": [
                {
                  "key": "type",
                  "value": "content",
                  "description": "content or quiz"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Sessions",
      "item": [
        {
          "name": "Get Active Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["sessions"]
            }
          }
        },
        {
          "name": "Revoke Session (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/sessions/<SESSION_ID>",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "<SESSION_ID>"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Enrollments",
      "item": [
        {
          "name": "Enroll User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"self\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enrollments",
              "host": ["{{baseUrl}}"],
              "path": ["enrollments"]
            }
          }
        },
        {
          "name": "Get My Enrollments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/enrollments/my",
              "host": ["{{baseUrl}}"],
              "path": ["enrollments", "my"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Organization Sponsorship",
      "item": [
        {
          "name": "Sponsor Users",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userEmails\": [\"user@test.com\"],\n  \"paymentMethod\": \"self\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/organizations/sponsor",
              "host": ["{{baseUrl}}"],
              "path": ["organizations", "sponsor"]
            }
          }
        }
      ]
    },
    {
      "name": "7. Content & Quizzes",
      "item": [
        {
          "name": "Get Daily Content",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/daily",
              "host": ["{{baseUrl}}"],
              "path": ["content", "daily"]
            }
          }
        },
        {
          "name": "Watch Video",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/content/video/watch",
              "host": ["{{baseUrl}}"],
              "path": ["content", "video", "watch"]
            }
          }
        },
        {
          "name": "Get Quiz Questions for Day",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quizzes/1",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "1"]
            }
          }
        },
        {
          "name": "Attempt Quiz",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    { \"questionIndex\": 0, \"selectedOption\": 1 },\n    { \"questionIndex\": 1, \"selectedOption\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes/attempt",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "attempt"]
            }
          }
        }
      ]
    },
    {
      "name": "8. Stats",
      "item": [
        {
          "name": "Get My Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/stats/my",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "my"]
            }
          }
        }
      ]
    }
  ]
}
